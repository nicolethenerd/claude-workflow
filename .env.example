# JIRA
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
# Label that marks a ticket as eligible for agent pickup
JIRA_AGENT_LABEL=claude-agent
# Label added when agent is waiting for human input
JIRA_BLOCKED_LABEL=agent-blocked

# Slack (socket mode — no public URL required for local dev)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...       # Enable Socket Mode in your Slack app settings
# Per-project Slack channels are configured in projects.json

# GitHub
GITHUB_TOKEN=ghp_...

# Scheduler
WORKER_CRON_SCHEDULE=0 7-23 * * *  # Top of every hour, 7am–11pm
CRON_TIMEZONE=America/New_York

# Workspace
# Where agents clone repos and write files. Each task gets its own subdirectory.
WORKSPACE_DIR=/Users/you/claude-workflow-workspaces

# Feature toggles
CLAUDE_ENABLED=true   # Set to false to disable the Claude agent (keeps /task JIRA creation working)
